# Copy this file to ".env" (git-ignored) and fill it in to run Ziusudra.Client.IntegrationTests
# against a real Deluge daemon. Leave it absent and the tests skip.
# The loader also honours these values if they are already set as environment variables.
ZIUSUDRA_DELUGE_HOST=deluge.local
ZIUSUDRA_DELUGE_PORT=58846
ZIUSUDRA_DELUGE_USERNAME=
ZIUSUDRA_DELUGE_PASSWORD=
