# Copy this file to ".env" (git-ignored) to run Ziusudra.Client.IntegrationTests against a Deluge
# daemon. Leave it absent and the tests skip. Real environment variables take precedence over these.
#
# The defaults below target the throwaway container in test/deluge (docker compose up).
ZIUSUDRA_DELUGE_HOST=127.0.0.1
ZIUSUDRA_DELUGE_PORT=58846
ZIUSUDRA_DELUGE_USERNAME=deluge
ZIUSUDRA_DELUGE_PASSWORD=deluge
